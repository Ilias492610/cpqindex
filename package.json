{
  "name": "cpq-indexation",
  "version": "1.0.0",
  "description": "CPQ Indexation CAP project with preview flow.",
  "dependencies": {
    "@cap-js/postgres": "^2",
    "@sap-cloud-sdk/connectivity": "^4.5.1",
    "@sap-cloud-sdk/http-client": "^4.5.1",
    "@sap/cds": "^9",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-indexation-ui": "cds watch --profile hybrid --open cpq.indexation.indexationui/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/indexation-ui"
  ],
  "cds": {
    "requires": {
      "connectivity": true,
      "destinations": true
    },
    "[development]": {
      "requires": {
        "db": {
          "kind": "sqlite",
          "credentials": {
            "url": "db.sqlite"
          }
        }
      }
    },
    "[production]": {
      "requires": {
        "db": "postgres"
      }
    }
  }
}