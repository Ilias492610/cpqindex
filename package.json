{
  "name": "cpq-indexation",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/postgres": "^2",
    "@sap-cloud-sdk/connectivity": "^4.5.1",
    "@sap-cloud-sdk/http-client": "^4.5.1",
    "@sap/cds": "^9",
    "dotenv": "^17.3.1",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-indexation-ui": "cds watch --open cpq.indexation.indexationui/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "connectivity": true,
      "destinations": true
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/indexation-ui"
  ]
}
